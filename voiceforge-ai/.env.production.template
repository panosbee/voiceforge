# ═══════════════════════════════════════════════════════════════════
# VoiceForge AI — Production Environment Template
# Copy to .env.production and fill in real values
# ⚠️  NEVER commit .env.production to version control!
# ═══════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_BASE_URL=https://api.YOUR_DOMAIN.com
FRONTEND_URL=https://YOUR_DOMAIN.com
LOG_LEVEL=info

# ── Encryption (generate with: openssl rand -hex 32) ─────────────
ENCRYPTION_KEY=

# ── Supabase ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://voiceforge:YOUR_DB_PASSWORD@postgres:5432/voiceforge
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379

# ── Telnyx ────────────────────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_SMS_FROM_NUMBER=

# ── ElevenLabs ────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_WEBHOOK_SECRET=

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=

# ── GDPR Data Retention (days) ───────────────────────────────────
DATA_RETENTION_CALLS_DAYS=365
DATA_RETENTION_WEBHOOKS_DAYS=90

# ── Docker (used by docker-compose.production.yml) ────────────────
POSTGRES_DB=voiceforge
POSTGRES_USER=voiceforge
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# ── Next.js (Frontend) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=https://api.YOUR_DOMAIN.com
NEXT_PUBLIC_DEV_AUTH=false
