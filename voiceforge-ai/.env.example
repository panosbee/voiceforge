# ═══════════════════════════════════════════════════════════════════
# VoiceForge AI — Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════════════════════════════════

# ─── APP ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=debug

# ─── ENCRYPTION ───────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of stored API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── DATABASE (Docker local) ─────────────────────────────────────
DATABASE_URL=postgresql://voiceforge:voiceforge_dev_2024@localhost:5432/voiceforge

# ─── DEV AUTH (JWT-based, no Supabase needed) ─────────────────────
NEXT_PUBLIC_DEV_AUTH=true
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── SUPABASE (optional in dev — used in production) ─────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── ADMIN ────────────────────────────────────────────────────────
# Admin secret for /admin panel access
# ADMIN_SECRET=voiceforge-admin-2026
# ADMIN_EMAIL=admin@voiceforge.ai

# ─── TELNYX (Greek phone numbers + SIP) ──────────────────────────
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=

# ─── STRIPE (Billing) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ─── GOOGLE CALENDAR (OAuth2 — optional) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# ─── WEB PUSH (VAPID — optional) ─────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@voiceforge.ai

# ─── RESEND (Transactional email) ─────────────────────────────────
RESEND_API_KEY=

# ─── OPENAI (Support chatbot) ────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── ELEVENLABS (AI Voice Agents) ────────────────────────────────
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=
ELEVENLABS_WEBHOOK_SECRET=
